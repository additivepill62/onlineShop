<Window x:Class="onlineShop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:onlineShop"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <ResourceDictionary Source="Resources/Dictionary1.xaml" />
    </Window.Resources>
    <DockPanel>
        <StackPanel DockPanel.Dock="Left" Width="200" Background="Gray">
            <ListView >

                <ListViewItem x:Name="termektipus1" 
                                  Content="termektipus1"
                                  MouseLeftButtonUp="termektipus1_MouseLeftButtonUp"
               
                />
                <ListViewItem x:Name="termektipus2" 
                              Content="termektipus2"
                              MouseLeftButtonUp="termektipus2_MouseLeftButtonUp"
                              />
                <ListViewItem x:Name="termektipus3" 
                              Content="termektipus3"
                              MouseLeftButtonUp="termektipus3_MouseLeftButtonUp"
                              />


            </ListView>
        </StackPanel>


        <StackPanel DockPanel.Dock="Right" Background="LightGray"></StackPanel>
    </DockPanel>
        
</Window>
