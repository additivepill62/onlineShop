<UserControl x:Class="onlineShop.UserControls.TermekUC3"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:onlineShop.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    
    <ItemsControl x:Name="TermekLista3">
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Border Background="LightGray" Margin="5" Padding="6" CornerRadius="4">
                    <StackPanel Width="150">
                        <Rectangle Width="100" Height="100" Fill="LightGreen"
                               HorizontalAlignment="Center" />
                        <DockPanel Margin="4,6,4,0">
                            <TextBlock Text="{Binding Nev}"
                                   DockPanel.Dock="Left"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="90" />
                            <TextBlock Text="{Binding Ar, StringFormat={}{0:C}}"
                                   DockPanel.Dock="Right"
                                   FontSize="14"
                                   TextAlignment="Right" />
                        </DockPanel>
                        <TextBlock Margin="4,4,4,0"
                               TextAlignment="Center"
                               Background="LightYellow">
                            <TextBlock.Text>
                                <Binding Path="RaktarKeszlet" StringFormat="Készleten: {0}" />
                            </TextBlock.Text>
                            <TextBlock.Foreground>
                                <Binding Path="RaktarKeszlet">
                                    <Binding.Converter>
                                        <local:KeszletColorConverter />
                                    </Binding.Converter>
                                </Binding>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <Button Content="Kosárba"
                            Margin="0,10,0,0"
                            Width="120"
                            Tag="{Binding}"
                            Click="KosarBTN_Click" />
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
    </ItemsControl>
</UserControl>
