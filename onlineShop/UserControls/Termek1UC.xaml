<UserControl x:Class="onlineShop.UserControls.Termek1UC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:onlineShop.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="700">

    <!--
        hozzáadás: 
    -->
    <UserControl.Resources>
        <DataTemplate x:Key="TermekKartyaTemplate">
            <Border Background="LightGray" Margin="8" Padding="6" CornerRadius="4">
                <StackPanel Width="150">
                    <!-- Termékkép helye (placeholder) -->
                    <Rectangle Width="120" Height="100" Fill="Moccasin"
                               HorizontalAlignment="Center" />

                    <!-- Név és ár egy sorban -->
                    <DockPanel Margin="4,6,4,0">
                        <TextBlock Text="{Binding Nev}"
                                   DockPanel.Dock="Left"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="90" />
                        <TextBlock Text="{Binding Ar, StringFormat={}{0:C}}"
                                   DockPanel.Dock="Right"
                                   TextAlignment="Right" />
                    </DockPanel>

                    <!-- Raktárkészlet -->
                    <TextBlock Margin="4,2,4,0"
                               TextAlignment="Center"
                               Background="LightYellow">
                        <TextBlock.Text>
                            <Binding Path="RaktarKeszlet" StringFormat="Készleten: {0}" />
                        </TextBlock.Text>
                        <TextBlock.Foreground>
                            <Binding Path="RaktarKeszlet">
                                <Binding.Converter>
                                    <local:KeszletColorConverter />
                                </Binding.Converter>
                            </Binding>
                        </TextBlock.Foreground>
                    </TextBlock>

                    <!-- Kosárba gomb – a Tag-en keresztül adjuk át a terméket -->
                    <Button Content="Kosárhoz adás"
                            Margin="0,8,0,0"
                            Width="120"
                            Tag="{Binding}"
                            Click="KosarBTN_Click" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    
    <ItemsControl x:Name="TermekLista"
                  ItemTemplate="{StaticResource TermekKartyaTemplate}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
    </ItemsControl>

</UserControl>
