<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Name="ListViewItem" TargetType="ListViewItem">
        <Setter Property="Margin" Value="15,15,15,0"></Setter>
        <Setter Property="Height" Value="20"></Setter>
        <Setter Property="Background" Value="#bdbdbd"></Setter>
    </Style>
    <Style x:Name="ListView" TargetType="ListView">
        <Setter Property="Background" Value="#f1f1f1"></Setter>
    </Style>
</ResourceDictionary>